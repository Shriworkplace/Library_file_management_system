rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users Collection
    match /users/{uid} {
      allow read, write: if true;
    }

    // Books Collection
    match /books/{bookId} {
      allow read, write: if true;
    }

    // Reviews Subcollection under Books
    match /books/{bookId}/reviews/{userId} {
      allow read, write: if true;
    }

    // BookCopies Collection
    match /bookCopies/{copyId} {
      allow read, write: if true;
    }

    // Issues Collection
    match /issues/{issueId} {
      allow read, write: if true;
    }

    // IssueRequests Collection
    match /issueRequests/{requestId} {
      allow read, write: if true;
    }

    // Reservations Collection
    match /reservations/{reservationId} {
      allow read, write: if true;
    }

    // ReadingLists Collection
    match /readingLists/{listId} {
      allow read, write: if true;
    }

    // SkillRoadmaps Collection
    match /skillRoadmaps/{skillId} {
      allow read, write: if true;
    }

    // StudentRoadmapProgress Collection
    match /studentRoadmapProgress/{progressId} {
      allow read, write: if true;
    }

    // Resources Collection
    match /resources/{resourceId} {
      allow read, write: if true;
    }

    // Fines Collection
    match /fines/{fineId} {
      allow read, write: if true;
    }

    // Research Papers Collection
    match /researchPapers/{paperId} {
      allow read, write: if true;
    }
  }
}
